{
  "name": "@js-webs/language-basics",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript基础",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "hello-js": "node src/hello.js",
    "hello-ts": "npx ts-node src/hello.ts",
    "promise-usage": "npx ts-node src/basic/promise-usage.ts",
    "node-process": "npx ts-node src/node-usage/process-usage.ts arg1 arg2",
    "node-console": "npx ts-node src/node-usage/console-usage.ts",
    "node-path": "npx ts-node src/node-usage/path-usage.ts",
    "node-os": "npx ts-node src/node-usage/os-usage.ts",
    "node-fs": "npx ts-node src/node-usage/fs-usage.ts",
    "node-http": "npx ts-node src/node-usage/http-usage.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
